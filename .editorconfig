# Roslynator 全局配置
[*.cs]

# --- Roslynator 类别级别设置 ---
# 可设为: none | silent | suggestion | warning | error
dotnet_analyzer_diagnostic.category-Roslynator.style.severity = suggestion
dotnet_analyzer_diagnostic.category-Roslynator.usage.severity = warning
dotnet_analyzer_diagnostic.category-Roslynator.simplification.severity = suggestion
dotnet_analyzer_diagnostic.category-Roslynator.design.severity = warning
dotnet_analyzer_diagnostic.category-Roslynator.maintainability.severity = warning
dotnet_analyzer_diagnostic.category-Roslynator.Roslyn.severity = suggestion
dotnet_analyzer_diagnostic.category-Roslynator.formatting.severity = suggestion

# --- Unity / Harmony 相关：关闭反射相关误报 ---
# Unity 魔法方法 (Update, Awake, Start 等) 通过反射调用
dotnet_diagnostic.IDE0051.severity = none
dotnet_diagnostic.RCS1213.severity = none
# Harmony 通过参数名注入，分析器不识别
dotnet_diagnostic.IDE0060.severity = none
dotnet_diagnostic.RCS1163.severity = none

# --- 常用规则微调 ---
# RCS1001: 添加花括号 (建议加上)
dotnet_diagnostic.RCS1001.severity = warning

# RCS1021: 简化 lambda 表达式
dotnet_diagnostic.RCS1021.severity = suggestion

# RCS1059: 避免 lock(this)
dotnet_diagnostic.RCS1059.severity = warning

# RCS1090: AddOrRemoveConfigureAwaitFalse (Unity 项目不需要)
dotnet_diagnostic.RCS1090.severity = none

# RCS1018: 默认访问修饰符 (建议显式加上)
dotnet_diagnostic.RCS1018.severity = suggestion

# --- 通用格式化 ---
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# --- 命名规范 ---
dotnet_naming_rule.private_members_with_underscore.symbols  = private_fields
dotnet_naming_rule.private_members_with_underscore.style    = prefix_underscore
dotnet_naming_rule.private_members_with_underscore.severity = suggestion
dotnet_naming_symbols.private_fields.applicable_kinds   = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.prefix_underscore.capitalization = camel_case
dotnet_naming_style.prefix_underscore.required_prefix = _
